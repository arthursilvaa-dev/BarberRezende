@model BarberRezende.Web.Models.Admin.AdminDashboardVm

@{
    ViewData["Title"] = "Dashboard Administrativo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Capitaliza a primeira letra do mês para ficar bonito na tela
    var Culture = new System.Globalization.CultureInfo("pt-BR");
}

<div class="p-4 bg-light rounded shadow-sm">
    <h1 class="mb-3">Dashboard Administrativo</h1>
    <p class="text-muted">Resumo do sistema, faturamento e atalhos rápidos.</p>

    <h4 class="mt-4 mb-3 border-bottom pb-2">Faturamento</h4>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-success h-100 shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title text-uppercase fw-light">@Culture.TextInfo.ToTitleCase(Model.NomeMesAtual ?? "") (Atual)</h6>
                    <h2 class="display-6 fw-bold mb-0">@Model.FaturamentoMesAtual.ToString("C")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-white h-100 shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title text-uppercase fw-light text-muted">@Culture.TextInfo.ToTitleCase(Model.NomeMesAnterior ?? "")</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.FaturamentoMesAnterior.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-white h-100 shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title text-uppercase fw-light text-muted">@Culture.TextInfo.ToTitleCase(Model.NomeDoisMesesAtras ?? "")</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.FaturamentoDoisMesesAtras.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4 mb-3 border-bottom pb-2">Visão Geral</h4>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Total Clientes</h6>
                    <h2 class="fw-bold text-primary">@Model.TotalClientes</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Agendamentos</h6>
                    <h2 class="fw-bold text-success">@Model.TotalAgendamentos</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Serviços Ativos</h6>
                    <h2 class="fw-bold text-warning">@Model.TotalServicos</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Barbeiros</h6>
                    <h2 class="fw-bold text-danger">@Model.TotalBarbeiros</h2>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4 mb-3 border-bottom pb-2">Acesso Rápido</h4>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-center p-4">
                    <h5 class="card-title">Gerenciar Clientes</h5>
                    <p class="card-text text-muted small">Acesse a lista completa de clientes para editar ou cadastrar novos perfis.</p>
                    <a class="btn btn-outline-primary px-4 rounded-pill" asp-controller="Clientes" asp-action="Index">Abrir Módulo de Clientes</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-center p-4">
                    <h5 class="card-title">Gerenciar Agendamentos</h5>
                    <p class="card-text text-muted small">Controle a agenda, horários marcados e fluxo da barbearia.</p>
                    <a class="btn btn-outline-success px-4 rounded-pill" asp-controller="Agendamentos" asp-action="Index">Abrir Módulo de Agendamentos</a>
                </div>
            </div>
        </div>
    </div>
</div>