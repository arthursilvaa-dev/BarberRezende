@model BarberRezende.Web.Models.Servicos.ServicoVm

@{
    ViewData["Title"] = "Excluir Serviço";
}

<h2>Excluir Serviço</h2>

<div class="alert alert-warning mt-3">
    Tem certeza que deseja excluir o serviço abaixo?
</div>

<div class="card mt-3">
    <div class="card-body">
        <!-- IMPORTANTE: VM agora usa NomeServico -->
        <p><strong>Nome:</strong> @Model.NomeServico</p>
        <p><strong>Preço:</strong> R$ @Model.Preco</p>
        <p><strong>Duração:</strong> @Model.DuracaoMinutos min</p>
    </div>
</div>

<!--
    IMPORTANTE:
    - Seu controller tem um POST DeleteConfirmed
    - Então vamos chamar asp-action="DeleteConfirmed"
-->
<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
