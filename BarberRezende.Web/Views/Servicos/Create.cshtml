@model BarberRezende.Web.Models.Servicos.ServicoCreateVm

@{
    ViewData["Title"] = "Novo Serviço";
}

<h2>Novo Serviço</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Create" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <!-- IMPORTANTE: VM agora usa NomeServico -->
        <label asp-for="NomeServico" class="form-label"></label>
        <input asp-for="NomeServico" class="form-control" />
        <span asp-validation-for="NomeServico" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Preco" class="form-label"></label>
        <input asp-for="Preco" class="form-control" />
        <span asp-validation-for="Preco" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DuracaoMinutos" class="form-label"></label>
        <input asp-for="DuracaoMinutos" class="form-control" />
        <span asp-validation-for="DuracaoMinutos" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-dark">Salvar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
