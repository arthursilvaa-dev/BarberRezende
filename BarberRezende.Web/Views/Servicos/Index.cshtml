@model List<BarberRezende.Web.Models.Servicos.ServicoVm>

@{
    ViewData["Title"] = "Serviços";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    

    <a class="btn btn-primary" asp-action="Create">+ Novo Serviço</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-secondary">
        Nenhum serviço cadastrado.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle" id="servicosTable">

            <thead>
                <tr>
                    <th>Nome</th>
                    <th class="text-end">Preço</th>
                    <th class="text-end">Duração (min)</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <!-- IMPORTANTE: VM agora usa NomeServico -->
                    <td>@s.NomeServico</td>

                    <td class="text-end">R$ @s.Preco</td>
                    <td class="text-end">@s.DuracaoMinutos</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@s.Id">Editar</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@s.Id">Excluir</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
