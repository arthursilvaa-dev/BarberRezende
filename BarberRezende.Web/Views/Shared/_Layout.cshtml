<!DOCTYPE html>
<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<title>@ViewData["Title"] - Barber Rezende</title>

		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Bootstrap CSS -->
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
			  rel="stylesheet" />

		<!-- CSS opcional do projeto -->
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

		<!-- CSS específico para a página de login -->
		<link rel="stylesheet" href="~/css/login.css" />

	</head>
	<body>


		<!-- Navbar -->
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
			<div class="container">
				<a class="navbar-brand" asp-controller="Admin" asp-action="Index">
					<img src="~/img/LogoPNGleao.png" alt="Logo" style="height:70px; filter: drop-shadow(0 0 4px rgba(212,175,55,0.6));" />

					Barber Rezende
				</a>


				<button class="navbar-toggler" type="button" data-bs-toggle="collapse"
						data-bs-target="#menu">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="collapse navbar-collapse" id="menu">
					<ul class="navbar-nav ms-auto">
						<li class="nav-item">
							<a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Barbeiros" asp-action="Index">Barbeiros</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Servicos" asp-action="Index">Serviços</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Agendamentos" asp-action="Index">Agendamentos</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>


		@if (TempData["Success"] != null)
		{
		<div class="alert alert-success mt-3">
			@TempData["Success"]
		</div>
		}

		@if (TempData["Error"] != null)
		{
		<div class="alert alert-danger mt-3">
			@TempData["Error"]
		</div>
		}

		<!-- Conteúdo das páginas -->
		<main class="container my-4">
			@RenderBody()
		</main>

		<!-- Footer simples -->
		<footer class="text-center text-muted py-3">
			<small>© @DateTime.Now.Year - Barber Rezende</small>
		</footer>

		<!-- Bootstrap JS -->
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

		<script src="~/js/telefone-mask.js"></script>
		@RenderSection("Scripts", required: false)

	</body>
</html>
