@model BarberRezende.Web.Models.Clientes.ClienteUpdateVm

@{
    ViewData["Title"] = "Editar Cliente";
}

<h1 class="display-6 fw-bold mb-4">Editar Cliente</h1>

<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label"></label>
        <input asp-for="Telefone" class="form-control js-telefone" />
        <span asp-validation-for="Telefone" class="text-danger"></span>
    </div>

    <div class="mb-3">
    <label asp-for="Email" class="form-label"></label>
    <input asp-for="Email" class="form-control js-email" />
    <span asp-validation-for="Email" class="text-danger"></span>
</div>


    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/email-validator.js"></script>

    <script>
        TelefoneMask.bindPhoneMask(".js-telefone");
        EmailValidator.bindEmailValidation(".js-email");
    </script>
}



