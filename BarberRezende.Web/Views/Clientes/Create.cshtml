@model BarberRezende.Web.Models.Clientes.ClienteCreateVm

@{
    ViewData["Title"] = "Novo Cliente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Novo Cliente</h2>

<form method="post" class="mt-3">
    <div class="mb-3">
        <label class="form-label">Nome</label>
        <input class="form-control" name="Nome" value="@Model.Nome" />
        <span class="text-danger">@Html.ValidationMessage("Nome")</span>
    </div>

    <div class="mb-3">
        <label class="form-label">Telefone</label>
        <span asp-validation-for="Telefone" class="text-danger"></span>
        <input asp-for="Telefone" class="form-control js-telefone" />
    </div>

    <div class="mb-3">
    <label asp-for="Email" class="form-label"></label>
    <input asp-for="Email" class="form-control js-email" />
    <span asp-validation-for="Email" class="text-danger"></span>
</div>


    <button class="btn btn-primary" type="submit">Salvar</button>
    <a class="btn btn-secondary" asp-action="Index">Voltar</a>

    <div class="text-danger mt-3">
        @Html.ValidationSummary()
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/email-validator.js"></script>

    <script>
        TelefoneMask.bindPhoneMask(".js-telefone");
        EmailValidator.bindEmailValidation(".js-email");
    </script>
}





