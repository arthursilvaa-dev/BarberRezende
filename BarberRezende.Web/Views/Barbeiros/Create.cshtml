@model BarberRezende.Web.Models.Barbeiros.BarbeiroVm
@{ ViewData["Title"] = "Novo Barbeiro"; }

<h1 class="mb-4 fw-bold">Novo Barbeiro</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm p-4 border-0">

        <div class="card-premium p-4 mt-3">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-bold"></label>
                    <input asp-for="Nome" class="form-control" placeholder="Nome do profissional" required />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Especialidade" class="form-label fw-bold"></label>
                    <input asp-for="Especialidade" class="form-control" placeholder="Ex: Degradê, Barba Terapia, Freestyle..." />
                    <span asp-validation-for="Especialidade" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Salvar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                </div>
            </form>
        </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }