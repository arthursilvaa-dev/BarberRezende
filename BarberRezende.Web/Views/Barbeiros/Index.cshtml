@model IEnumerable<BarberRezende.Web.Models.Barbeiros.BarbeiroVm>

@{
    ViewData["Title"] = "Barbeiros";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <div>
        <h1 class="mb-1">Barbeiros</h1>
        <div class="text-muted">Gerencie a equipe de profissionais da barbearia.</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">+ Novo Barbeiro</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-hover align-middle" id="barbeirosTable">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Especialidade</th>
            <th class="text-end">Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted py-4">Nenhum barbeiro cadastrado.</td></tr>
        }
        else
        {
            foreach (var b in Model)
            {
                <tr>
                    <td>@b.Id</td>
                    <td class="fw-bold">@b.Nome</td>
                    <td>@b.Especialidade</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@b.Id">Editar</a>
                        
                        <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline" onsubmit="return confirm('Tem certeza que deseja remover @b.Nome?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Remover</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>